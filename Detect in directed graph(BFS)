from collections import deque
class Solution:
    def isCyclic(self, V, edges):
        adj=[]
        for _ in range(V):
            adj.append([])
        for u,v in edges:
            adj[u].append(v)
        indegree=[0]*V
        for u,v in edges:
            indegree[v]+=1
        q=deque([])
        for i in range(0,V):
            if(indegree[i]==0):
                q.append(i)
        ans=[]
        while(len(q)>0):
            node=q.popleft()
            ans.append(node)
            for adjNode in adj[node]:
                indegree[adjNode]-=1
                if(indegree[adjNode]==0):
                    q.append(adjNode)
        if(len(ans)!=V):
            return True
        return False
